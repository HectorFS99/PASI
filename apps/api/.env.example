# ------------------------------------------------------------
# Banco de dados (Neon / PostgreSQL)
# Pegue a connection string em: Neon Console -> seu projeto -> Connect
# Use a opção "Pooled connection" para DATABASE_URL.
# Mantenha sslmode=require.
# ------------------------------------------------------------
DATABASE_URL="postgresql://USUARIO:SENHA@ep-xxxx-pooler.REGIAO.aws.neon.tech/pasi?sslmode=require"

# Conexão direta (sem pooler) - usada pelo Prisma para introspecção/migrations
DIRECT_URL="postgresql://USUARIO:SENHA@ep-xxxx.REGIAO.aws.neon.tech/pasi?sslmode=require"

# ------------------------------------------------------------
# Aplicação
# ------------------------------------------------------------
PORT=3000

# ------------------------------------------------------------
# JWT - troque por um segredo longo e aleatório
# ------------------------------------------------------------
JWT_SECRET="troque-este-segredo-por-um-valor-aleatorio-e-longo"
JWT_EXPIRES_IN="1d"
